# Virtualenvs never live in this repo (and never on exFAT) — they go under ~/.venvs/
.venv/
venv/

# Throwaway spike area (cloned third-party repos, experiment scripts) — not for commit.
.spikes/

# Vendored third-party tools (Ableton Remote Scripts, MCP bridges) — each is its own clone
# with its own git history; symlinked into Live's Remote Scripts, not copied. Not for commit.
external/

# Python build/cache
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/
dist/

# macOS / exFAT litter
.DS_Store
._*
$RECYCLE.BIN/
System Volume Information/
